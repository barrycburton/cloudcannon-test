---
import { getCollection, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

export async function getStaticPaths() {
  const newsletter = (await getCollection('newsletter', ({ data }) => !data.draft)).sort(
    (a, b) => +b.data.date - +a.data.date,
  );

  return newsletter.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: newsletter[i + 1],
      next: newsletter[i - 1],
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);

const fmt = (d: Date) =>
  `${String(d.getDate()).padStart(2, '0')}.${String(d.getMonth() + 1).padStart(2, '0')}.${d.getFullYear()}`;
---

<PageLayout
  title={post.data.title}
  heroImage={post.data.image}
  pageTitle={`${post.data.title} — My Name`}
>
  <div class="post-meta">
    <span>{fmt(post.data.date)}</span>
  </div>

  {
    post.data.categories.length > 0 && (
      <div class="category-list" style="margin-top: 24px;">
        {post.data.categories.map((category) => (
          <a href={`/categories/${category}`}>{category}</a>
        ))}
      </div>
    )
  }

  <hr style="border:0;border-top:1px solid #94918f;margin:32px 0;" />

  <div class="prose">
    <editable-text data-prop="@content"> 
      <Content />
    </editable-text>
  </div>

  <nav class="post-nav" aria-label="Adjacent Letters">
    {
      prev ? (
        <a class="post-nav__prev" href={`/newsletter/${prev.id}`}>
          <span>← Previous</span>
          <strong>{prev.data.title}</strong>
        </a>
      ) : (
        <span />
      )
    }
    {
      next ? (
        <a class="post-nav__next" href={`/newsletter/${next.id}`}>
          <span>Next →</span>
          <strong>{next.data.title}</strong>
        </a>
      ) : (
        <span />
      )
    }
  </nav>
</PageLayout>
