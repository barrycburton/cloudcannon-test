---
import { getCollection, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

export async function getStaticPaths() {
  const newsletter = await getCollection('newsletter', ({ data }) => !data.draft);
  const work = await getCollection('work');
  const categories = new Set<string>();
  newsletter.forEach((p) => p.data.categories.forEach((t) => categories.add(t)));
  work.forEach((i) => i.data.categories.forEach((t) => categories.add(t)));

  return [...categories].map((category) => ({
    params: { category },
    props: {
      category,
      newsletter: newsletter
        .filter((p) => p.data.categories.includes(category))
        .sort((a, b) => +b.data.date - +a.data.date),
	  work: work
	    .filter((i) => i.data.categories.includes(category))
	    .sort((a, b) => +b.data.date - +a.data.date),
    },
  }));
}

export async function getExcerpt(post) {
  const {remarkPluginFrontmatter } = await render(post)
  return remarkPluginFrontmatter.excerpt
}

const { category, newsletter, work } = Astro.props;
const fmt = (d: Date) =>
  `${String(d.getDate()).padStart(2, '0')}.${String(d.getMonth() + 1).padStart(2, '0')}.${d.getFullYear()}`;
---

<PageLayout
  title={`#${category}`}
  eyebrow="Tag"
  description={`${newsletter.length + work.length} item${newsletter.length + work.length === 1 ? '' : 's'} categoryged ${category}.`}
>
  <div class="post-list">
    {
      newsletter.map((post) => (
        <a class="post-card" href={`/newsletter/${post.id}`}>
          <div class="post-card__image">
            <img src={post.data.image} alt="" loading="lazy" />
          </div>
          <div>
            <div class="post-card__meta">
              {fmt(post.data.date)}
            </div>
            <h2 class="post-card__title">{post.data.title}</h2>
            <p class="post-card__excerpt">{getExcerpt(post)}</p>
          </div>
        </a>
      ))
    }
 </div>
 <div class="post-list">
    {
      work.map((item) => (
        <a class="post-card" href={`/work/${item.id}`}>
          <div class="post-card__image">
            <img src={item.data.image} alt="" loading="lazy" />
          </div>
          <div>
            <div class="post-card__meta">
              {fmt(item.data.date)}
            </div>
            <h2 class="post-card__title">{item.data.title}</h2>
            <p class="post-card__excerpt">{item.data.summary}</p>
          </div>
        </a>
      ))
    }
  </div>
</PageLayout>
