---
interface Props {
  title: string;
  date: Date;
  cover: string;
  summary: string;
  order: number;
  href: string;
}

const { title, date, cover, summary, order, href } = Astro.props;

const formatted = new Intl.DateTimeFormat('en-GB', {
  day: '2-digit',
  month: '2-digit',
  year: 'numeric',
})
  .format(date)
  .replaceAll('/', '.');

---

<div class="blog-header">
  <div class="blog-article header-article">
    <div class="blog-big__title">{title}</div>
    <div class="blog-menu small-title date">{formatted}</div>
  </div>
  <div class="blog-article">
    <img src={cover} alt={title} />
    <h2>
      {summary}
    </h2>
    <a href={href}>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="feather feather-corner-down-right"
        viewBox="0 0 24 24"
      >
        <path d="M15 10l5 5-5 5"></path>
        <path d="M4 4v7a4 4 0 004 4h12"></path>
      </svg>
      See More
    </a>
  </div>
</div>