---
import BaseLayout from './BaseLayout.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  heroImage?: string;
  pageTitle?: string;
}

const { title, description, eyebrow, heroImage, pageTitle } = Astro.props;
const headTitle = pageTitle ?? `${title} — My Name`;
---

<BaseLayout title={headTitle} description={description} image={heroImage}>
  <div class="page">
    <header class="page-nav">
      <a class="page-nav__brand" href="/">My Name</a>
      <nav aria-label="Primary">
        <a href="/work">Work</a>
        <a href="/newsletter">Newsletter</a>
		<a href="/about">About</a>
      </nav>
    </header>

    <main class="page-main">
      {
        heroImage && (
          <div class="page-hero">
            <img src={heroImage} alt="" />
          </div>
        )
      }

      <section class="page-head">
        {eyebrow && <div class="page-eyebrow">{eyebrow}</div>}
        <h1 class="page-title" data-editable="text" data-prop="title">{title}</h1>
        {description && <p class="page-deck">{description}</p>}
      </section>

      <div class="page-body">
        <slot />
      </div>
    </main>

    <Footer />
  </div>
</BaseLayout>
