---
import { getCollection, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

export async function getStaticPaths() {
  const work = (await getCollection('work', ({ data }) => !data.draft)).sort(
    (a, b) => +b.data.date - +a.data.date,
  );

  return work.map((item, i) => ({
    params: { slug: item.id },
    props: {
      item,
      prev: work[i + 1],
      next: work[i - 1],
    },
  }));
}

const { item, prev, next } = Astro.props;
const { Content } = await render(item);

const fmt = (d: Date) =>
  `${String(d.getDate()).padStart(2, '0')}.${String(d.getMonth() + 1).padStart(2, '0')}.${d.getFullYear()}`;
---

<PageLayout
  title={item.data.title}
>
  <div class="post-meta">
    <span>{fmt(item.data.date)}</span>
  </div>

  {
    item.data.categories.length > 0 && (
      <div class="category-list" style="margin-top: 24px;">
        {item.data.categories.map((category) => (
          <a href={`/categories/${category}`}>{category}</a>
        ))}
      </div>
    )
  }

  <img data-editable="image" data-prop-src="image" src={item.data.image} alt="" loading="lazy" />
  
  <div class="work-item__summary">
    <Content />
  </div>

  <nav class="post-nav" aria-label="Adjacent Work">
    {
      prev ? (
        <a class="post-nav__prev" href={`/work/${prev.id}`}>
          <span>← Previous</span>
          <strong>{prev.data.title}</strong>
        </a>
      ) : (
        <span />
      )
    }
    {
      next ? (
        <a class="post-nav__next" href={`/work/${next.id}`}>
          <span>Next →</span>
          <strong>{next.data.title}</strong>
        </a>
      ) : (
        <span />
      )
    }
  </nav>
</PageLayout>
